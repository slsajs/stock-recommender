# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=stock_recommender
DB_USER=postgres
DB_PASSWORD=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# DART API
DART_API_KEY=

# ECOS API (한국은행 경제통계 — 고도화 STEP A~C)
# 발급: https://ecos.bok.or.kr/ → 로그인 → Open API → 인증키 신청 (무료)
# 기준금리(BASE_RATE), 원달러환율(USD_KRW), 국고채10년물(KTB_10Y) 수집에 사용
# 미설정 시 재무 내부 가중치는 기본값(PER 30%, ROE 30%)으로 고정
ECOS_API_KEY=

# Slack (7단계)
SLACK_WEBHOOK_URL=

# 스케줄링
SCHEDULE_HOUR=16
SCHEDULE_MINUTE=30